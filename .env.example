# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15

# OpenAI fallback provider (use this instead of Azure OpenAI if preferred)
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
AI_ENABLE_DEMO_FALLBACK=true
AI_PROVIDER_MAX_RETRIES=1
AI_PROVIDER_RETRY_BASE_MS=700
AI_PROVIDER_RETRY_MAX_MS=2500

# Groq provider (optional, fast hosted inference)
# Create a key at https://console.groq.com/keys
# AI_PROVIDER=groq
# GROQ_API_KEY=gsk-your-groq-key
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Local AI provider (optional, no cloud key; requires Ollama installed and running)
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# Azure Speech
AZURE_SPEECH_KEY=your-speech-key-here
AZURE_SPEECH_REGION=eastus

# Azure Cosmos DB
COSMOS_DB_CONNECTION_STRING=your-cosmos-connection-string
COSMOS_DB_NAME=ai4a

# Azure SQL
AZURE_SQL_CONNECTION_STRING=your-sql-connection-string

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=your-storage-connection-string
AZURE_STORAGE_CONTAINER_NAME=ai4a-uploads

# Azure Redis Cache
AZURE_REDIS_CONNECTION_STRING=rediss://:your-password@your-cache.redis.cache.windows.net:6380
REDIS_URL=rediss://:your-password@your-cache.redis.cache.windows.net:6380
RATE_LIMIT_STORE=memory

# Azure AD B2C (Authentication)
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_CLIENT_SECRET=your-client-secret
AZURE_AD_REDIRECT_URI=http://localhost:3000

# Application
NODE_ENV=development
PORT=4000
JWT_SECRET=your-super-secret-jwt-key-change-in-production
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000
DEMO_DATA_FILE=./data/demo-db.json
AUTH_PASSWORD_RESET_DRY_RUN=true
API_RATE_LIMIT_MAX=600
AI_RATE_LIMIT_MAX=30
AI_ACTION_RATE_LIMIT_MAX=20
DEBUG_API_REQUESTS=false

# Partner inquiry email
# In local demos, leave RESEND_API_KEY empty and set PARTNER_INQUIRY_DRY_RUN=true.
RESEND_API_KEY=
PARTNER_EMAIL_TO=partnerships@example.com
PARTNER_INQUIRY_DRY_RUN=true

# Supabase (Authentication)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key
# Configure Google and Microsoft providers in Supabase Auth dashboard, then set callback URL:
# http://localhost:4000/api/auth/oauth/google/callback
# http://localhost:4000/api/auth/oauth/microsoft/callback

# Frontend
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_API_URL=http://localhost:4000
VITE_APP_NAME=Avora

# Logging
LOG_LEVEL=info
